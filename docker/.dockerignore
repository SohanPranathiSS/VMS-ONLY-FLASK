# Docker ignore patterns
**/.git
**/.gitignore
**/README.md
**/.env
**/.env.example
**/.env.production

# Node.js
**/node_modules
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*

# Python
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
**/.Python
**/env
**/pip-log.txt
**/pip-delete-this-directory.txt
**/.tox
**/.coverage
**/.coverage.*
**/coverage.xml
***/.pytest_cache/
**/htmlcov/

# IDEs
**/.vscode
**/.idea
**/*.swp
**/*.swo
**/Thumbs.db
**/.DS_Store

# OS
**/.DS_Store
**/Thumbs.db

# Logs
**/logs
**/*.log

# Temporary files
**/tmp
**/temp
**/*.tmp
**/*.temp

# Test files
**/tests
**/*.test.js
**/*.spec.js

# Documentation
**/docs
**/*.md
!**/README.md

# Build artifacts
**/build
**/dist
**/out

# SSL certificates (security)
**/ssl
**/*.pem
**/*.key
**/*.crt

# Database files
**/*.db
**/*.sqlite
**/*.sqlite3

# Backup files
**/*.backup
**/*.bak

# Development tools
**/.pytest_cache
**/.coverage
**/htmlcov
**/.venv
**/venv

# Docker files (avoid recursion)
**/Dockerfile*
**/docker-compose*
**/.dockerignore
