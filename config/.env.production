# =============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION  
# =============================================================================
# Optimized for production deployment with security and performance

# Environment
NODE_ENV=production
LOG_LEVEL=info
TZ=Asia/Kolkata

# Service Configuration
FRONTEND_PORT=3000
BACKEND_PORT=4000
ML_PORT=5000

FLASK_HOST=0.0.0.0
FLASK_PORT=4000
FLASK_DEBUG=false
FLASK_ENV=production

ML_HOST=0.0.0.0
ML_DEBUG=false

# URLs (UPDATE WITH YOUR PRODUCTION DOMAINS)
FRONTEND_URL=https://your-domain.com
BACKEND_URL=https://api.your-domain.com
ML_URL=https://ml.your-domain.com
REACT_APP_API_BASE_URL=https://api.your-domain.com/api
REACT_APP_ML_SERVICE_URL=https://ml.your-domain.com

# Database (Production)
DB_HOST=your_production_db_host
DB_PORT=3306
DB_NAME=visitor_management_prod
DB_USER=vms_prod_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# MySQL Docker Variables
MYSQL_ROOT_PASSWORD=CHANGE_THIS_STRONG_ROOT_PASSWORD
MYSQL_DATABASE=visitor_management_prod
MYSQL_USER=vms_prod_user
MYSQL_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# Security (MUST CHANGE FOR PRODUCTION)
SECRET_KEY=CHANGE_THIS_VERY_STRONG_SECRET_KEY_MINIMUM_32_CHARACTERS
JWT_SECRET=CHANGE_THIS_VERY_STRONG_JWT_SECRET_KEY_MINIMUM_32_CHARACTERS

# CORS (Restrictive for production)
ALLOWED_HOSTS=your-domain.com,www.your-domain.com,api.your-domain.com
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# File Uploads
UPLOAD_FOLDER=/app/uploads
MAX_FILE_SIZE=16777216
MAX_CONTENT_LENGTH=16777216
BACKEND_UPLOAD_FOLDER=/app/uploads
ML_UPLOAD_FOLDER=/app/static/uploads

# Email (Production SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USER=your_production_email@company.com
EMAIL_PASS=CHANGE_THIS_EMAIL_APP_PASSWORD
EMAIL_USERNAME=your_production_email@company.com
EMAIL_PASSWORD=CHANGE_THIS_EMAIL_APP_PASSWORD

# AI/ML Configuration
GOOGLE_API_KEY=CHANGE_THIS_PRODUCTION_GOOGLE_API_KEY
GEMINI_MODEL=gemini-pro
EASYOCR_LANGUAGES=en
EASYOCR_GPU=false
EASYOCR_DOWNLOAD_ENABLED=true

# Production Features
DEBUG=false
HOT_RELOAD=false
SOURCE_MAPS=false
REACT_APP_DEBUG=false

# Service Communication
ML_SERVICE_URL=https://ml.your-domain.com
BACKEND_SERVICE_URL=https://api.your-domain.com

# SSL Configuration
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/private.key

# Monitoring & Error Tracking
SENTRY_DSN=CHANGE_THIS_SENTRY_DSN_FOR_ERROR_TRACKING

# Performance & Caching
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
