# =============================================================================
# ML SERVICE ENVIRONMENT TEMPLATE
# =============================================================================
# AI-powered ML Service Environment Variables
# Copy this to ML/.env and customize for your environment

# Server Configuration
ML_HOST=0.0.0.0
ML_PORT=5000
ML_DEBUG=false
PORT=5000

# Google Gemini AI Configuration
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-pro
GEMINI_TEMPERATURE=0.1
GEMINI_MAX_TOKENS=1000

# EasyOCR Configuration
EASYOCR_LANGUAGES=en
EASYOCR_GPU=false
EASYOCR_DOWNLOAD_ENABLED=true
EASYOCR_MODEL_STORAGE_DIRECTORY=models

# File Upload Configuration
UPLOAD_FOLDER=static/uploads
MAX_FILE_SIZE=16777216
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# Service Communication
BACKEND_SERVICE_URL=http://localhost:4000
FRONTEND_SERVICE_URL=http://localhost:3000

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/ml.log

# AI Processing Configuration
CONFIDENCE_THRESHOLD=0.5
MAX_PROCESSING_TIME=30
BATCH_SIZE=1

# Model Configuration
MODEL_CACHE_SIZE=100
MODEL_CACHE_TTL=3600
PRELOAD_MODELS=true

# Performance Configuration
WORKER_PROCESSES=1
WORKER_THREADS=4
MAX_REQUESTS=1000
MAX_REQUESTS_JITTER=100

# Image Processing Configuration
MAX_IMAGE_WIDTH=2048
MAX_IMAGE_HEIGHT=2048
IMAGE_QUALITY=85
SUPPORTED_FORMATS=jpeg,jpg,png,pdf

# Error Handling
RETRY_ATTEMPTS=3
RETRY_DELAY=1
FALLBACK_ENABLED=true

# Production Overrides (uncomment for production)
# ML_DEBUG=false
# LOG_LEVEL=warning
# EASYOCR_GPU=true
# WORKER_PROCESSES=4
# GOOGLE_API_KEY=your_production_google_api_key
# ALLOWED_ORIGINS=https://your-domain.com
# CORS_ORIGINS=https://your-domain.com,https://api.your-domain.com
