# =============================================================================
# TESTING ENVIRONMENT CONFIGURATION
# =============================================================================
# Optimized for automated testing with fast execution and mocking

# Environment
NODE_ENV=test
LOG_LEVEL=error
TZ=UTC

# Service Configuration
FRONTEND_PORT=3001
BACKEND_PORT=4001
ML_PORT=5001

FLASK_HOST=127.0.0.1
FLASK_PORT=4001
FLASK_DEBUG=false
FLASK_ENV=testing

ML_HOST=127.0.0.1
ML_DEBUG=false

# URLs (Test)
FRONTEND_URL=http://localhost:3001
BACKEND_URL=http://localhost:4001
ML_URL=http://localhost:5001
REACT_APP_API_BASE_URL=http://localhost:4001/api
REACT_APP_ML_SERVICE_URL=http://localhost:5001

# Database (In-memory/Test)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=visitor_management_test
DB_USER=test_user
DB_PASSWORD=test_password

# Security (Test keys)
SECRET_KEY=test-secret-key-for-testing-only-not-secure
JWT_SECRET=test-jwt-secret-for-testing-only-minimum-32-characters

# CORS (Permissive for testing)
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3001,http://localhost:8001
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8001

# File Uploads (Test)
UPLOAD_FOLDER=test_uploads
MAX_FILE_SIZE=1048576
BACKEND_UPLOAD_FOLDER=./test_uploads
ML_UPLOAD_FOLDER=test_static/uploads

# Email (Mock for testing)
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USE_TLS=false
EMAIL_USER=test@example.com
EMAIL_PASS=test_password

# AI/ML Configuration (Mock/Test)
GOOGLE_API_KEY=test_google_api_key_for_testing
GEMINI_MODEL=gemini-pro
EASYOCR_LANGUAGES=en
EASYOCR_GPU=false
EASYOCR_DOWNLOAD_ENABLED=false

# Testing Features
DEBUG=false
HOT_RELOAD=false
SOURCE_MAPS=false
REACT_APP_DEBUG=false
TESTING=true

# Service Communication (Test)
ML_SERVICE_URL=http://localhost:5001
BACKEND_SERVICE_URL=http://localhost:4001

# Test Database Settings
TEST_DATABASE_URL=sqlite:///:memory:
USE_MOCK_SERVICES=true
