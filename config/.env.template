# =============================================================================
# VISITOR MANAGEMENT SYSTEM - MASTER ENVIRONMENT TEMPLATE
# =============================================================================
# This is the master template containing ALL environment variables used across
# the entire application stack. Copy and customize for different environments.
#
# Security Note: This is a TEMPLATE file. Never commit actual secrets!
# =============================================================================

# =============================================================================
# GLOBAL CONFIGURATION
# =============================================================================
NODE_ENV=development
LOG_LEVEL=info
TZ=Asia/Kolkata

# =============================================================================
# SERVICE PORTS & URLS
# =============================================================================
# Frontend (React Application)
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000

# Backend (Flask API)
BACKEND_PORT=4000
BACKEND_URL=http://localhost:4000
FLASK_HOST=0.0.0.0
FLASK_PORT=4000
FLASK_DEBUG=true
FLASK_ENV=development

# ML Service (AI Processing)
ML_PORT=5000
ML_URL=http://localhost:5000
ML_HOST=0.0.0.0
ML_DEBUG=false

# API Endpoints
REACT_APP_API_BASE_URL=http://localhost:4000/api
REACT_APP_ML_SERVICE_URL=http://localhost:5000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# MySQL Database Settings
DB_HOST=localhost
DB_PORT=3306
DB_NAME=visitor_management_dev
DB_USER=vms_user
DB_PASSWORD=your_db_password_here

# Production Database (uncomment for production)
# MYSQL_ROOT_PASSWORD=your_strong_root_password
# MYSQL_DATABASE=visitor_management_prod
# MYSQL_USER=vms_prod_user
# MYSQL_PASSWORD=your_strong_prod_password

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Flask & JWT Secrets (MUST be changed for production)
SECRET_KEY=dev-secret-key-change-in-production
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars

# CORS & Security
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
UPLOAD_FOLDER=uploads
MAX_FILE_SIZE=16777216
MAX_CONTENT_LENGTH=16777216

# Service-specific upload folders
BACKEND_UPLOAD_FOLDER=./uploads
ML_UPLOAD_FOLDER=static/uploads

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
# SMTP Settings (Gmail example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Alternative email settings
EMAIL_USERNAME=your_email@company.com
EMAIL_PASSWORD=your_email_app_password

# =============================================================================
# AI/ML SERVICE CONFIGURATION
# =============================================================================
# Google Gemini AI
GOOGLE_API_KEY=your_google_gemini_api_key_here
GEMINI_MODEL=gemini-pro

# EasyOCR Configuration
EASYOCR_LANGUAGES=en
EASYOCR_GPU=false
EASYOCR_DOWNLOAD_ENABLED=true

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================
# Service URLs for inter-service communication
ML_SERVICE_URL=http://localhost:5000
BACKEND_SERVICE_URL=http://localhost:4000

# Third-party APIs
SENTRY_DSN=your_sentry_dsn_for_error_tracking

# =============================================================================
# PERFORMANCE & CACHING
# =============================================================================
# Redis Configuration (optional)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# SSL/HTTPS CONFIGURATION (Production)
# =============================================================================
# SSL Certificate paths (uncomment for production)
# SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
# SSL_KEY_PATH=/etc/nginx/ssl/private.key

# =============================================================================
# BACKUP & MONITORING
# =============================================================================
# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================
# Debug flags
DEBUG=true
FLASK_DEBUG=true
REACT_APP_DEBUG=true

# Development tools
HOT_RELOAD=true
SOURCE_MAPS=true

# =============================================================================
# PRODUCTION OVERRIDES
# =============================================================================
# Uncomment and modify for production deployment
# NODE_ENV=production
# FLASK_ENV=production
# FLASK_DEBUG=false
# DEBUG=false
# LOG_LEVEL=error
# 
# # Production URLs
# FRONTEND_URL=https://your-domain.com
# BACKEND_URL=https://api.your-domain.com
# ML_URL=https://ml.your-domain.com
# 
# # Production CORS
# CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
# ALLOWED_HOSTS=your-domain.com,www.your-domain.com
