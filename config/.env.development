# =============================================================================
# DEVELOPMENT ENVIRONMENT CONFIGURATION
# =============================================================================
# Optimized for local development with debugging and hot reload enabled

# Environment
NODE_ENV=development
LOG_LEVEL=debug
TZ=Asia/Kolkata

# Service Configuration
FRONTEND_PORT=3000
BACKEND_PORT=4000
ML_PORT=5000

FLASK_HOST=0.0.0.0
FLASK_PORT=4000
FLASK_DEBUG=true
FLASK_ENV=development

ML_HOST=0.0.0.0
ML_DEBUG=true

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
ML_URL=http://localhost:5000
REACT_APP_API_BASE_URL=http://localhost:4000/api
REACT_APP_ML_SERVICE_URL=http://localhost:5000

# Database (Local Development)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=visitor_management_dev
DB_USER=root
DB_PASSWORD=root

# Security (Development - NOT for production)
SECRET_KEY=dev-secret-key-for-local-development-only
JWT_SECRET=dev-jwt-secret-for-local-development-minimum-32-characters

# CORS (Permissive for development)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# File Uploads
UPLOAD_FOLDER=uploads
MAX_FILE_SIZE=16777216
BACKEND_UPLOAD_FOLDER=./uploads
ML_UPLOAD_FOLDER=static/uploads

# Email (Development - use test credentials)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USER=test@example.com
EMAIL_PASS=test_password

# AI/ML Configuration
GOOGLE_API_KEY=your_development_google_api_key_here
GEMINI_MODEL=gemini-pro
EASYOCR_LANGUAGES=en
EASYOCR_GPU=false
EASYOCR_DOWNLOAD_ENABLED=true

# Development Features
DEBUG=true
HOT_RELOAD=true
SOURCE_MAPS=true
REACT_APP_DEBUG=true

# Service Communication
ML_SERVICE_URL=http://localhost:5000
BACKEND_SERVICE_URL=http://localhost:4000
