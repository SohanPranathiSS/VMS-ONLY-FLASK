# Production Environment Variables
# Copy this file to .env and update with your production values

# Database Configuration
MYSQL_ROOT_PASSWORD=your_strong_root_password_here
MYSQL_DATABASE=visitor_management_prod
MYSQL_USER=vms_user
MYSQL_PASSWORD=your_strong_db_password_here

# Flask Configuration
FLASK_ENV=production
JWT_SECRET_KEY=your_very_strong_jwt_secret_key_here_min_32_chars
SECRET_KEY=your_very_strong_flask_secret_key_here

# Email Configuration (for notifications)
EMAIL_USERNAME=your_email@company.com
EMAIL_PASSWORD=your_email_app_password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# Security Configuration
ALLOWED_HOSTS=your-domain.com,www.your-domain.com,localhost
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# SSL Configuration (for HTTPS)
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/private.key

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# Monitoring Configuration
LOG_LEVEL=INFO
SENTRY_DSN=your_sentry_dsn_for_error_tracking

# Performance Configuration
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# File Upload Configuration
MAX_CONTENT_LENGTH=16777216  # 16MB
UPLOAD_FOLDER=/app/uploads
